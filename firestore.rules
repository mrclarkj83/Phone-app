rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function signedInEmail() {
      return request.auth.token.email;
    }

    function isAdmin() {
      return signedIn() && signedInEmail() == "joseph.clark@doralacademynv.org";
    }

    function teacherPath() {
      return /databases/$(database)/documents/teachers/$(signedInEmail());
    }

    function isTeacher() {
      return signedIn() && exists(teacherPath());
    }

    function isAssignedTeacher(studentId) {
      return isTeacher() && studentId in get(teacherPath()).data.studentIds;
    }

    function canReadOwnDoc(path) {
      return signedIn() && (!exists(path) || resource.data.studentEmail == signedInEmail());
    }

    function canWriteOwnRosterDoc(studentId) {
      return signedIn() &&
        request.resource.data.studentId == studentId &&
        request.resource.data.studentEmail == signedInEmail();
    }

    match /teachers/{teacherEmail} {
      allow get: if isAdmin() || (signedIn() && teacherEmail == signedInEmail());
      allow list, create, update, delete: if isAdmin();
    }

    match /roles/{roleEmail} {
      allow get: if isAdmin() || (signedIn() && roleEmail == signedInEmail());
      allow list, create, update, delete: if isAdmin();
    }

    match /assignments/{assignmentId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();

      match /progress/{studentId} {
        allow get: if isAdmin() ||
          isAssignedTeacher(studentId) ||
          canReadOwnDoc(/databases/$(database)/documents/assignments/$(assignmentId)/progress/$(studentId));
        allow list: if isAdmin();
        allow create, update: if isAdmin() || canWriteOwnRosterDoc(studentId);
        allow delete: if isAdmin();
      }

      match /submissions/{studentId} {
        allow get: if isAdmin() ||
          isAssignedTeacher(studentId) ||
          canReadOwnDoc(/databases/$(database)/documents/assignments/$(assignmentId)/submissions/$(studentId));
        allow list: if isAdmin();
        allow create, update: if isAdmin() || canWriteOwnRosterDoc(studentId);
        allow delete: if isAdmin();
      }
    }
  }
}
