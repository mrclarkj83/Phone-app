rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "joseph.clark@doralacademynv.org";
    }

    function teacherPath() {
      return /databases/(default)/documents/teachers/$(request.auth.token.email);
    }

    function isAssignedTeacherReport(fileName) {
      return signedIn() &&
        firestore.exists(teacherPath()) &&
        fileName in firestore.get(teacherPath()).data.reportFiles;
    }

    function ownsRosterReport(fileName) {
      return signedIn() && (
        (request.auth.token.email == "amaya.solbes@student.doralacademynv.org" && fileName == "S1001.json") ||
        (request.auth.token.email == "austin.davis@student.doralacademynv.org" && fileName == "S1002.json") ||
        (request.auth.token.email == "camila.lopez@student.doralacademynv.org" && fileName == "S1003.json") ||
        (request.auth.token.email == "tony.mkhitaryan@student.doralacademynv.org" && fileName == "S1004.json") ||
        (request.auth.token.email == "emme.nguyen@student.doralacademynv.org" && fileName == "S1005.json") ||
        (request.auth.token.email == "brilynn.moates@student.doralacademynv.org" && fileName == "S1006.json") ||
        (request.auth.token.email == "elias.terry@student.doralacademynv.org" && fileName == "S1007.json") ||
        (request.auth.token.email == "raevyn.moore@student.doralacademynv.org" && fileName == "S1008.json") ||
        (request.auth.token.email == "madison.osborn@student.doralacademynv.org" && fileName == "S1009.json") ||
        (request.auth.token.email == "antony.stoev@student.doralacademynv.org" && fileName == "S1010.json") ||
        (request.auth.token.email == "capri.vickers@student.doralacademynv.org" && fileName == "S1011.json") ||
        (request.auth.token.email == "joshua.hearne@student.doralacademynv.org" && fileName == "S1012.json") ||
        (request.auth.token.email == "lillian.akers@student.doralacademynv.org" && fileName == "S1013.json") ||
        (request.auth.token.email == "zoe.tomlinson@student.doralacademynv.org" && fileName == "S1014.json") ||
        (request.auth.token.email == "zaim.ishola@student.doralacademynv.org" && fileName == "S1015.json") ||
        (request.auth.token.email == "presley.peterson@student.doralacademynv.org" && fileName == "S1016.json") ||
        (request.auth.token.email == "evan.hernandez@student.doralacademynv.org" && fileName == "S1017.json") ||
        (request.auth.token.email == "mason.peraza@student.doralacademynv.org" && fileName == "S1018.json") ||
        (request.auth.token.email == "melia.mosley@student.doralacademynv.org" && fileName == "S1019.json") ||
        (request.auth.token.email == "rayden.canda@student.doralacademynv.org" && fileName == "S1020.json") ||
        (request.auth.token.email == "julian.pitura@student.doralacademynv.org" && fileName == "S1021.json") ||
        (request.auth.token.email == "elijan.rosas@student.doralacademynv.org" && fileName == "S1022.json") ||
        (request.auth.token.email == "madyson.jezbera@student.doralacademynv.org" && fileName == "S1023.json") ||
        (request.auth.token.email == "naol.kassaya@student.doralacademynv.org" && fileName == "S1024.json") ||
        (request.auth.token.email == "gabriella.novo@student.doralacademynv.org" && fileName == "S1025.json")
      );
    }

    match /assignments/{assignmentId}/submissions/{fileName} {
      allow read: if isAdmin() || isAssignedTeacherReport(fileName) || ownsRosterReport(fileName);
      allow write: if isAdmin() || ownsRosterReport(fileName);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
